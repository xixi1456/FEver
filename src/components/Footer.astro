---
// 页脚 - 六边形+圆形队徽
---

<footer class="border-t border-[var(--color-border)] py-6" role="contentinfo">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-3">
    <div class="flex items-center gap-2 cyber-corners p-1">
      <!-- 六边形+圆形队徽 - hover旋转 -->
      <div class="relative w-6 h-6">
        <svg class="absolute inset-0 w-full h-full transition-transform duration-500 hover:rotate-[45deg]" viewBox="0 0 40 40" fill="none" aria-hidden="true">
          <path d="M20 3L36 11.5V28.5L20 37L4 28.5V11.5L20 3Z" stroke="var(--color-neon-green)" stroke-width="1.2"/>
        </svg>
        <img src={import.meta.env.BASE_URL + "images/logo-nav.png"} alt="Fever" class="absolute" style="top:50%;left:50%;transform:translate(-50%,-50%);width:55%;height:55%;object-fit:contain;" width="22" height="22" loading="lazy"/>
      </div>
      <span class="text-xs text-stroke tracking-[0.2em] font-mono" style="-webkit-text-stroke-color: var(--color-neon-green)">ROBMASTER FEVER</span>
    </div>
    <p class="text-[10px] text-[var(--color-text-dim)]/60 font-mono">&copy; 2026 河北工业职业技术大学</p>
  </div>
</footer>
