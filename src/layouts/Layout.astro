---
import '../styles/global.css'
interface Props { title: string }
const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ROBMASTER Fever战队 - 河北工业职业技术大学 | 嵌入式·算法·机械" />
    <meta name="theme-color" content="#050507" />
    <meta property="og:title" content="FEVER | ROBMASTER 战队" />
    <meta property="og:description" content="河北工业职业技术大学 ROBMASTER Fever 战队官网" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={import.meta.env.BASE_URL + "images/logo-circle.png"} />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=Noto+Sans+SC:wght@400;500;700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="grid-bg crt-scanlines min-h-screen antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[99999] focus:px-4 focus:py-2 focus:bg-[var(--color-neon-green)] focus:text-[var(--color-bg)] focus:rounded">跳到主要内容</a>

    <!-- 滚动进度条 -->
    <div id="scroll-progress" aria-hidden="true"></div>

    <!-- 自定义光标 -->
    <div id="cursor-dot" aria-hidden="true"></div>
    <div id="cursor-ring" aria-hidden="true"></div>

    <!-- 全站粒子背景 -->
    <canvas id="particle-canvas" class="fixed inset-0 pointer-events-none z-0" aria-hidden="true"></canvas>

    <slot />

    <noscript>
      <style>#loading-screen { display: none !important; }</style>
    </noscript>

    <script>
      import gsap from 'gsap';
      import ScrollTrigger from 'gsap/ScrollTrigger';
      gsap.registerPlugin(ScrollTrigger);

      // ===== 全站粒子背景 =====
      const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;
      const dpr = window.devicePixelRatio || 1;

      function resizeCanvas() {
        canvas.width = window.innerWidth * dpr;
        canvas.height = window.innerHeight * dpr;
        canvas.style.width = window.innerWidth + 'px';
        canvas.style.height = window.innerHeight + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }
      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);

      const count = window.innerWidth < 768 ? 25 : 50;
      const pts: {x:number;y:number;vx:number;vy:number;r:number;a:number}[] = [];
      for (let i = 0; i < count; i++) {
        pts.push({ x: Math.random()*window.innerWidth, y: Math.random()*window.innerHeight, vx:(Math.random()-0.5)*0.4, vy:(Math.random()-0.5)*0.4, r: Math.random()*1.5+0.5, a: Math.random()*0.4+0.1 });
      }

      function drawParticles() {
        const w = window.innerWidth, h = window.innerHeight;
        ctx.clearRect(0,0,w,h);
        pts.forEach(p => {
          p.x += p.vx; p.y += p.vy;
          if (p.x<0) p.x=w; if (p.x>w) p.x=0;
          if (p.y<0) p.y=h; if (p.y>h) p.y=0;
          ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
          ctx.fillStyle = `rgba(0,255,136,${p.a})`; ctx.fill();
        });
        for (let i=0;i<pts.length;i++) {
          for (let j=i+1;j<pts.length;j++) {
            const d = Math.hypot(pts[i].x-pts[j].x, pts[i].y-pts[j].y);
            const linkDist = window.innerWidth < 768 ? 100 : 130;
            if (d<linkDist) {
              ctx.beginPath(); ctx.moveTo(pts[i].x,pts[i].y); ctx.lineTo(pts[j].x,pts[j].y);
              ctx.strokeStyle=`rgba(0,255,136,${0.08*(1-d/linkDist)})`; ctx.lineWidth=0.5; ctx.stroke();
            }
          }
        }
        requestAnimationFrame(drawParticles);
      }
      drawParticles();

      // ===== 滚动进度条 =====
      const scrollProgress = document.getElementById('scroll-progress')!;
      window.addEventListener('scroll', () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = (scrollTop / docHeight) * 100;
        scrollProgress.style.width = progress + '%';
      });

      // ===== 自定义光标（美术AI：SVG变形+data-cursor文字） =====
      const dot = document.getElementById('cursor-dot')!;
      const ring = document.getElementById('cursor-ring')!;
      let mouseX = 0, mouseY = 0;
      let ringX = 0, ringY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX; mouseY = e.clientY;
        dot.style.left = mouseX - 4 + 'px';
        dot.style.top = mouseY - 4 + 'px';
      });

      function animateRing() {
        ringX += (mouseX - ringX) * 0.15;
        ringY += (mouseY - ringY) * 0.15;
        ring.style.left = ringX - 18 + 'px';
        ring.style.top = ringY - 18 + 'px';
        requestAnimationFrame(animateRing);
      }
      animateRing();

      // 普通hover效果
      document.querySelectorAll('a, button, .card-hover, .faq-item').forEach((el) => {
        el.addEventListener('mouseenter', () => { dot.classList.add('hovering'); ring.classList.add('hovering'); });
        el.addEventListener('mouseleave', () => { dot.classList.remove('hovering'); ring.classList.remove('hovering'); dot.removeAttribute('data-cursor-text'); });
      });

      // data-cursor 属性：显示对应文字
      document.querySelectorAll('[data-cursor]').forEach((el) => {
        el.addEventListener('mouseenter', () => {
          dot.classList.add('hovering');
          ring.classList.add('hovering');
          const text = el.getAttribute('data-cursor');
          if (text) dot.setAttribute('data-cursor-text', text);
        });
        el.addEventListener('mouseleave', () => {
          dot.classList.remove('hovering');
          ring.classList.remove('hovering');
          dot.removeAttribute('data-cursor-text');
        });
      });

      // ===== 磁力按钮 (JIEJOO 018+美术AI) =====
      document.querySelectorAll('[data-magnetic]').forEach((btn) => {
        const strength = parseFloat(btn.getAttribute('data-magnetic-strength') || '0.3');
        btn.addEventListener('mousemove', (e) => {
          const rect = btn.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          gsap.to(btn, { x: x * strength, y: y * strength, duration: 0.4, ease: 'power2.out' });
        });
        btn.addEventListener('mouseleave', () => {
          gsap.to(btn, { x: 0, y: 0, duration: 0.6, ease: 'elastic.out(1, 0.3)' });
        });
      });

      // ===== 卡片3D Tilt (美术AI) =====
      document.querySelectorAll('.group-card, .card-tilt').forEach((card) => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top) / rect.height - 0.5;
          card.classList.add('tilting');
          gsap.to(card, { rotateY: x * 8, rotateX: -y * 8, duration: 0.3, transformPerspective: 1000 });
        });
        card.addEventListener('mouseleave', () => {
          card.classList.remove('tilting');
          gsap.to(card, { rotateY: 0, rotateX: 0, duration: 0.6, ease: 'elastic.out(1, 0.3)' });
        });
      });

      // ===== Lenis =====
      import Lenis from 'lenis';
      const lenis = new Lenis({ lerp: 0.08 });
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => { lenis.raf(time * 1000); });
      gsap.ticker.lagSmoothing(0);

      // ===== IntersectionObserver =====
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
      }, { threshold: 0.15 });
      document.querySelectorAll('.fade-up, .stroke-draw, .reveal-clip').forEach((el) => { observer.observe(el); });

      // ===== SVG描边长度 =====
      document.querySelectorAll('.stroke-draw').forEach((el) => {
        const pathEl = el as SVGPathElement | SVGLineElement | SVGCircleElement | SVGPolygonElement;
        if ('getTotalLength' in pathEl) {
          const length = pathEl.getTotalLength();
          pathEl.style.setProperty('--len', String(Math.ceil(length)));
        }
      });

      // ===== ScrollTrigger 场景动画 (美术AI) =====

      // 大标题向上推移
      document.querySelectorAll('h2').forEach((h) => {
        gsap.from(h, {
          scrollTrigger: { trigger: h, start: 'top 85%', end: 'top 50%', scrub: 1 },
          y: 60, opacity: 0
        });
      });

      // 门派卡片3D入场
      document.querySelectorAll('.group-card').forEach((card, i) => {
        gsap.from(card, {
          scrollTrigger: { trigger: card, start: 'top 90%' },
          y: 80, opacity: 0, duration: 1, delay: i * 0.1
        });
      });

      // 数据计数器GSAP动画（替代setInterval）
      document.querySelectorAll('[data-count]').forEach((el) => {
        const target = parseInt(el.dataset.count || '0');
        const obj = { val: 0 };
        ScrollTrigger.create({
          trigger: el, start: 'top 80%',
          onEnter: () => {
            gsap.to(obj, {
              val: target, duration: 2, ease: 'power2.out',
              onUpdate: () => { el.textContent = Math.floor(obj.val) + (target > 10 ? '+' : ''); }
            });
          }
        });
      });

      // ===== 锚点偏移 =====
      document.querySelectorAll('section[id]').forEach((section) => {
        (section as HTMLElement).style.scrollMarginTop = '80px';
      });

      // ===== 标签页暂停 =====
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) { lenis.stop(); } else { lenis.start(); }
      });
    </script>
  </body>
</html>
