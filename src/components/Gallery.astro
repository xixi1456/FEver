<script>
  import gsap from 'gsap';

  const container = document.getElementById('infinite-gallery')!;
  const inner = document.getElementById('gallery-inner')!;
  const items = inner.querySelectorAll('.gallery-item');
  const itemWidth = (items[0] as HTMLElement).offsetWidth + 20;
  const halfCount = items.length / 2;
  const halfWidth = halfCount * itemWidth;

  // ========== 状态 ==========
  let currentX = 0;
  let isDragging = false;
  let dragStartPointerX = 0;   // 拖拽起始指针位置
  let dragStartCurrentX = 0;   // 拖拽起始时的 currentX
  let lastDx = 0;
  let velocity = 0;
  let lastMoveTime = 0;
  let lastMovePointerX = 0;

  // 惯性补间引用（统一管理，mouse/touch 共用）
  let activeTween: gsap.core.Tween | null = null;

  // ========== 核心：应用位置 + 边界穿越 ==========
  function applyPosition() {
    // 边界穿越（无限循环）
    if (currentX < -halfWidth) {
      currentX += halfWidth;
    }
    if (currentX > 0) {
      currentX -= halfWidth;
    }
    gsap.set(inner, { x: currentX });
  }

  // ========== 工具：kill 活跃补间 ==========
  function killActiveTween() {
    if (activeTween) {
      activeTween.kill();
      activeTween = null;
    }
  }

  // ========== 工具：计算速度 ==========
  function updateVelocity(pointerX: number, now: number) {
    if (lastMoveTime > 0 && now - lastMoveTime < 100) {
      velocity = pointerX - lastMovePointerX;
    }
    lastMovePointerX = pointerX;
    lastMoveTime = now;
  }

  // ========== 鼠标拖拽 ==========
  container.addEventListener('mousedown', (e) => {
    killActiveTween();
    isDragging = true;
    dragStartPointerX = e.pageX;
    dragStartCurrentX = currentX;
    lastDx = 0;
    lastMoveTime = 0;
    container.style.cursor = 'grabbing';
  });

  window.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    const dx = e.pageX - dragStartPointerX;
    lastDx = dx;
    currentX = dragStartCurrentX + dx;
    updateVelocity(e.pageX, Date.now());
    applyPosition();
  });

  window.addEventListener('mouseup', () => {
    if (!isDragging) return;
    isDragging = false;
    container.style.cursor = 'grab';
    launchInertia(lastDx);
  });

  // ========== 触摸拖拽 ==========
  container.addEventListener('touchstart', (e) => {
    killActiveTween();
    isDragging = true;
    dragStartPointerX = e.touches[0].pageX;
    dragStartCurrentX = currentX;
    lastDx = 0;
    lastMoveTime = 0;
  }, { passive: true });

  container.addEventListener('touchmove', (e) => {
    if (!isDragging) return;
    const pointerX = e.touches[0].pageX;
    const dx = pointerX - dragStartPointerX;
    lastDx = dx;
    currentX = dragStartCurrentX + dx;
    updateVelocity(pointerX, Date.now());
    applyPosition();
  }, { passive: true });

  container.addEventListener('touchend', () => {
    isDragging = false;
    launchInertia(lastDx);
  });

  // ========== 惯性启动（统一入口）==========
  function launchInertia(v: number) {
    killActiveTween();
    if (Math.abs(v) < 3) return;
    const targetX = currentX + v * 12;
    activeTween = gsap.to({ x: currentX }, {
      x: targetX,
      duration: 1.0,
      ease: 'power3.out',
      onUpdate() {
        currentX = this.targets()[0].x;
        applyPosition();
      },
      onComplete() {
        activeTween = null;
      }
    });
  }

  // ========== 自动缓慢漂移 ==========
  let autoScroll: ReturnType<typeof setInterval> | null = null;

  function startAutoScroll() {
    stopAutoScroll();
    autoScroll = setInterval(() => {
      if (!isDragging && !activeTween) {
        currentX -= 0.5;
        applyPosition();
      }
    }, 16);
  }

  function stopAutoScroll() {
    if (autoScroll) {
      clearInterval(autoScroll);
      autoScroll = null;
    }
  }

  // 只在可视区域内自动滚动
  const galleryObserver = new IntersectionObserver(([entry]) => {
    if (entry.isIntersecting) {
      startAutoScroll();
    } else {
      stopAutoScroll();
    }
  }, { threshold: 0.1 });

  galleryObserver.observe(container);
</script>
